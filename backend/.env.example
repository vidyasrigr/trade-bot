# ============================================================
# Copy this to .env and fill in real values
# ============================================================

# Database
POSTGRES_USER=options
POSTGRES_PASSWORD=options_secret
POSTGRES_DB=options_trading
DATABASE_URL=postgresql://options:options_secret@localhost:5432/options_trading

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Tradier (paper trading)
TRADIER_API_KEY=your_tradier_api_key
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Alpha Vantage (technical indicators + fundamentals + macro)
ALPHA_VANTAGE_API_KEY=your_av_key

# FRED (Federal Reserve Economic Data — VIX, DXY, yield curve)
FRED_API_KEY=your_fred_key

# NewsAPI (news headlines)
NEWS_API_KEY=your_newsapi_key

# Financial Modeling Prep (analyst targets, earnings calendar)
FMP_API_KEY=your_fmp_key

# Ollama (local RTX 5080 — set to remote IP when running on PC)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Twilio (optional SMS alerts for N)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# App settings
APP_ENV=development
LOG_LEVEL=INFO
MARKET_OPEN_ET=09:30
MARKET_CLOSE_ET=16:00
MAX_PORTFOLIO_HEAT=0.30          # max % of capital deployed at once
MAX_SECTOR_CONCENTRATION=0.35    # max % in one sector
MAX_NET_DELTA_BIAS=0.60          # max directional tilt
POSITION_MONITOR_INTERVAL=900    # seconds (15 min)
STAGE1_MIN_OPTIONS_VOLUME=500000 # min daily options $ volume to enter universe
